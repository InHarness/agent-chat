{
  "name": "@inharness/agent-chat",
  "version": "0.1.0",
  "description": "React chat UI kit for @inharness/agent-adapters — drop-in components and hooks for AI agent conversations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      }
    },
    "./styles": "./dist/styles/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@inharness/agent-adapters": ">=0.1.0",
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@inharness/agent-adapters": { "optional": false },
    "express": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "dependencies": {
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "rehype-highlight": "^7.0.0"
  },
  "devDependencies": {
    "@inharness/agent-adapters": "file:../agent-adapters",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "chat",
    "react",
    "components",
    "hooks",
    "streaming",
    "claude",
    "codex",
    "gemini"
  ],
  "license": "MIT",
  "author": "InHarness"
}
