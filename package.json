{
  "name": "@inharness-ai/agent-chat",
  "version": "0.1.0",
  "description": "React chat UI kit for @inharness-ai/agent-adapters — drop-in components and hooks for AI agent conversations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      }
    },
    "./styles": "./dist/styles/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "c4s": "npx claude4spec --pages .claude/skills"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@inharness-ai/agent-adapters": ">=0.2.0",
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@inharness-ai/agent-adapters": { "optional": false },
    "express": { "optional": true },
    "react": { "optional": false },
    "react-dom": { "optional": false }
  },
  "dependencies": {
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "rehype-highlight": "^7.0.0"
  },
  "devDependencies": {
    "@inharness-ai/agent-adapters": "^0.2.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "chat",
    "react",
    "components",
    "hooks",
    "streaming",
    "claude",
    "codex",
    "gemini"
  ],
  "license": "MIT",
  "author": "InHarness",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InHarness/agent-chat.git"
  },
  "bugs": {
    "url": "https://github.com/InHarness/agent-chat/issues"
  },
  "homepage": "https://github.com/InHarness/agent-chat#readme",
  "publishConfig": {
    "access": "public"
  }
}
